# =============================================================================
# CVPM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# =============================================================================
# FRONTEND — Vite (VITE_ prefix required, exposed to browser bundle)
# =============================================================================

# Supabase project URL (required)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (required)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe publishable key (required for checkout)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Canonical app URL — no trailing slash (required for OG tags, redirects)
VITE_APP_URL=http://localhost:8080

# Guesty Edge Function proxy URL
VITE_GUESTY_FN_URL=https://your-project-ref.supabase.co/functions/v1/guesty-proxy

# Dev server port (optional, defaults to 8080)
# VITE_PORT=8080

# =============================================================================
# BACKEND — Supabase Edge Function Secrets
# Set via: supabase secrets set KEY=value
# These are NEVER exposed to the frontend.
# =============================================================================

# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# GUESTY_BE_CLIENT_ID=your_guesty_client_id
# GUESTY_BE_CLIENT_SECRET=your_guesty_client_secret

# =============================================================================
# CI / TURBOREPO REMOTE CACHE
# Set as GitHub Actions secrets and Vercel env vars.
# Vercel injects TURBO_TOKEN + TURBO_TEAM automatically.
# =============================================================================

# TURBO_TOKEN=your_vercel_access_token
# TURBO_TEAM=your_vercel_team_slug
# TURBO_REMOTE_CACHE_SIGNATURE_KEY=your_signing_key
