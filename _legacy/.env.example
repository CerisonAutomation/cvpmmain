# Canonical names (app) — Vercel may use aliases; backend/env_bootstrap.py maps them.
# Pull from Vercel:  vercel env pull .env.local --environment=production
# Sync local files: ./scripts/sync-vercel-env.sh

# --- Backend (required for booking) ---
MONGO_URL=
# Vercel alias: MONGODB_URI
DB_NAME=cvpm
GUESTY_BEAPI_CLIENT_ID=
GUESTY_BEAPI_CLIENT_SECRET=
STRIPE_API_KEY=
# Vercel alias: STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=
# Vercel aliases: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=
OPENROUTER_API_KEY=
JWT_SECRET=
ADMIN_PASSWORD=
CORS_ORIGINS=https://www.christianopropertymanagement.com,https://christianopropertymanagement.com
ENV=development

# --- Frontend (Vite — set on Vercel for builds) ---
VITE_BACKEND_URL=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
